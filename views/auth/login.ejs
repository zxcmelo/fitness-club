<%- include('../partials/header', { title: 'Вход' }) %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Вход в аккаунт</h1>
    <p class="auth-sub">Добро пожаловать обратно!</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (typeof query !== 'undefined' && query && query.reset === '1') { %>
      <div class="alert alert-success">Пароль успешно изменён. Войдите с новым паролем.</div>
    <% } %>

    <!-- Показываем уведомление о сбросе пароля -->
    <script>
      if (new URLSearchParams(window.location.search).get('reset') === '1') {
        document.addEventListener('DOMContentLoaded', () => {
          const a = document.querySelector('.alert-success');
          if (!a) {
            const div = document.createElement('div');
            div.className = 'alert alert-success';
            div.textContent = 'Пароль успешно изменён. Войдите с новым паролем.';
            document.querySelector('form').before(div);
          }
        });
      }
    </script>

    <form action="/auth/login" method="POST" id="loginForm" novalidate>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="ivan@example.com" required>
      </div>

      <div class="form-group">
        <label for="password">Пароль</label>
        <input type="password" id="password" name="password" placeholder="Ваш пароль" required>
      </div>

      <div class="form-options">
        <a href="/auth/forgot-password" class="link-muted">Забыли пароль?</a>
      </div>

      <button type="submit" class="btn btn-primary btn-full">Войти</button>
    </form>

    <div class="oauth-divider"><span>или</span></div>
    <button class="btn btn-google" onclick="alert('OAuth через Google будет добавлен в следующей версии.')">
      <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#4285F4" d="M44.5 20H24v8.5h11.8C34.7 33.9 30.1 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.1 0 5.9 1.1 8.1 2.9l6.4-6.4C34.6 5.1 29.6 3 24 3 12.9 3 4 11.9 4 23s8.9 20 20 20c11 0 19.5-7.7 19.5-20 0-1.3-.1-2.7-.3-4h-.2z"/></svg>
      Войти через Google
    </button>

    <p class="auth-footer">
      Нет аккаунта? <a href="/auth/register">Зарегистрироваться</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
