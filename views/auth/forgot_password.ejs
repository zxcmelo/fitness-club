<%- include('../partials/header', { title: 'Восстановление пароля' }) %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Забыли пароль?</h1>
    <p class="auth-sub">Введите email — мы пришлём ссылку для сброса</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (message) { %>
      <div class="alert alert-success"><%= message %></div>
    <% } %>

    <% if (!message) { %>
    <form action="/auth/forgot-password" method="POST">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email"
               placeholder="ivan@example.com" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Отправить ссылку</button>
    </form>
    <% } %>

    <p class="auth-footer"><a href="/auth/login">← Вернуться ко входу</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
