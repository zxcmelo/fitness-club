<%- include('../partials/header', { title: 'Панель администратора' }) %>

<div class="container section">
  <div class="page-header">
    <h1>👑 Панель администратора</h1>
    <div class="admin-stats-bar">
      Всего пользователей: <strong><%= users.length %></strong>
    </div>
  </div>

  <!-- Уведомления -->
  <% const msgs = {
    role_updated: '✅ Роль пользователя обновлена.',
    user_deleted: '✅ Пользователь удалён.',
    self: '❌ Нельзя изменить свои данные из панели администратора.',
    server: '❌ Ошибка сервера.',
  }; %>
  <% const key = success || (typeof query !== 'undefined' && query && query.error); %>
  <% if (key && msgs[key]) { %>
    <div class="alert alert-<%= success ? 'success' : 'error' %>"><%= msgs[key] %></div>
  <% } %>
  <script>
    const p = new URLSearchParams(window.location.search);
    const errorKey = p.get('error');
    const msgs = {
      self: '❌ Нельзя изменить свои данные.',
      server: '❌ Ошибка сервера.',
    };
    if (errorKey && msgs[errorKey]) {
      const div = document.createElement('div');
      div.className = 'alert alert-error';
      div.textContent = msgs[errorKey];
      document.querySelector('.page-header').after(div);
    }
  </script>

  <!-- Таблица пользователей -->
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>ФИО</th>
          <th>Email</th>
          <th>Роль</th>
          <th>Подтверждён</th>
          <th>Дата регистрации</th>
          <th>Действия</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr class="<%= u.id === user.id ? 'row-self' : '' %>">
          <td><%= u.id %></td>
          <td><%= u.full_name %></td>
          <td><%= u.email %></td>
          <td>
            <% if (u.id !== user.id) { %>
            <form action="/admin/users/<%= u.id %>/role" method="POST" class="inline-form">
              <select name="role" onchange="this.form.submit()" class="select-sm">
                <option value="client" <%= u.role === 'client' ? 'selected' : '' %>>Клиент</option>
                <option value="admin"  <%= u.role === 'admin'  ? 'selected' : '' %>>Админ</option>
              </select>
            </form>
            <% } else { %>
              <span class="badge-admin">Вы (admin)</span>
            <% } %>
          </td>
          <td><%= u.is_confirmed ? '✅' : '⏳' %></td>
          <td><%= new Date(u.created_at).toLocaleDateString('ru-RU') %></td>
          <td>
            <% if (u.id !== user.id) { %>
            <form action="/admin/users/<%= u.id %>/delete" method="POST" class="inline-form"
                  onsubmit="return confirm('Удалить пользователя <%= u.full_name %>?')">
              <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
            </form>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="admin-links">
    <a href="/workouts" class="btn btn-outline">Управление тренировками</a>
    <a href="/workouts/add" class="btn btn-primary">+ Добавить тренировку</a>
  </div>
</div>

<%- include('../partials/footer') %>
