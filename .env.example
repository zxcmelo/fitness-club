# =============================================
# Конфигурация приложения фитнес-клуба
# Скопируй этот файл в .env и заполни значения
# =============================================

# Сервер
PORT=3000
SESSION_SECRET=super_secret_key_change_me_in_production

# PostgreSQL (замени на свои данные)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fitness_club
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Почта (ethereal.email для тестирования — генерируется автоматически)
# Для реального SMTP раскомментируй и заполни:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# URL приложения (для ссылок в письмах)
APP_URL=http://localhost:3000
